# Server
NODE_ENV=production
PORT=5000

# Puppeteer — skip Chromium download (not used in production code path)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Browserless.io — optional, enables enhanced media extraction
# Get your key at https://browserless.io
BROWSERLESS_API_KEY=your_browserless_api_key_here

# Database — optional, not required for basic extraction functionality
# DATABASE_URL=postgresql://user:password@host:5432/dbname
